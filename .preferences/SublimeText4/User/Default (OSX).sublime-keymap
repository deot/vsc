	{ 
		"keys": ["command+l"], 
		"command": "terminus_open", 
		"args": {
			"cwd": "${file_path:${folder}}"
		}
	},
	{
		"keys": ["super+1"],
		"command": "lsp_code_actions",
		"args": {
