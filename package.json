{
  "name": "vsc-preferences",
  "displayName": "Deot Preferences",
  "description": "Personal Theme & Commands",
  "version": "1.0.8",
  "publisher": "deot",
  "repository": "https://dev.azure.com/zrd0921/vsc/_git/vsc",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Themes",
    "Formatters",
    "Other"
  ],
  "keywords": [
    "theme",
    "preference",
    "sublime text",
    "sublime merge"
  ],
  "activationEvents": [
    "workspaceContains:.git",
    "workspaceContains:**/.gitignore",
    "workspaceContains:**/.git/config"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "icon": "logo.png",
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Deot Theme Darker",
        "uiTheme": "vs-dark",
        "path": "./themes/deot-theme-darker.json"
      }
    ],
    "commands": [
      {
        "command": "revealFileInOS",
        "title": "Reveal In Finder"
      },
      {
        "command": "copyFilePath",
        "title": "Copy File Path"
      },
      {
        "command": "explorer.newFile",
        "title": "New File"
      },
      {
        "command": "explorer.newFolder",
        "title": "New Folder"
      },
      {
        "command": "workbench.action.terminal.openNativeConsole",
        "title": "Open Terminal Here"
      },
      {
        "command": "deot.debug",
        "title": "dd/Debug"
      },
      {
        "command": "deot.setSyntax",
        "title": "ss/Set Syntax"
      },
      {
        "command": "deot.pasteAndIndent",
        "title": "pasteAndIndent"
      },
      {
        "command": "deot.2spaceToTab",
        "title": "2spaceToTab"
      },
      {
        "command": "deot.4spaceToTab",
        "title": "4spaceToTab"
      },
      {
        "command": "deot.duplicateFile",
        "title": "Duplicate"
      },
      {
        "command": "deot.setColumns.One",
        "title": "setColumns/1"
      },
      {
        "command": "deot.setColumns.Two",
        "title": "setColumns/2"
      },
      {
        "command": "deot.setColumns.Three",
        "title": "setColumns/3"
      },
      {
        "command": "deot.lsp.fix.all",
        "title": "LSP-*"
      },
      {
        "command": "deot.lsp.fix.js",
        "title": "LSP-eslint"
      },
      {
        "command": "deot.lsp.fix.css",
        "title": "LSP-stylelint"
      },
       {
        "command": "deot.lsp.restart.all",
        "title": "LSP-*"
      },
      {
        "command": "deot.lsp.restart.js",
        "title": "LSP-eslint"
      },
      {
        "command": "deot.lsp.restart.css",
        "title": "LSP-stylelint"
      },
      {
        "command": "deot.lsp.restart.vue",
        "title": "LSP-volar"
      },
      {
        "command": "deot.lsp.restart.ts",
        "title": "LSP-typescript"
      },
      {
        "command": "deotsm.openInSublimeMerge",
        "title": "Open Git Repository..."
      },
      {
        "command": "deotsm.blameInSublimeMerge",
        "title": "Blame File..."
      },
      {
        "command": "deotsm.fileHistoryInSublimeMerge",
        "title": "File History..."
      },
      {
        "command": "deotsm.lineHistoryInSublimeMerge",
        "title": "Line History..."
      },
      {
        "command": "deotsm.myCommitsInSublimeMerge",
        "title": "Show My Commits..."
      }
    ],
    "keybindings": [
      {
        "key": "cmd+2",
        "command": "deot.2spaceToTab",
        "when": "editorFocus"
      },
      {
        "key": "cmd+4",
        "command": "deot.4spaceToTab",
        "when": "editorFocus"
      },
      {
        "key": "cmd+shift+v",
        "command": "deot.pasteAndIndent",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "cmd+alt+1",
        "command": "deot.setColumns.One"
      },
      {
        "key": "cmd+alt+2",
        "command": "deot.setColumns.Two"
      },
      {
        "key": "cmd+alt+3",
        "command": "deot.setColumns.Three"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "revealFileInOS",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        },
        {
          "command": "workbench.action.terminal.openNativeConsole",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        },
        {
          "command": "copyFilePath",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        },
        {
          "submenu": "deot.lsp.fix",
          "when": "config.deot.showMenu",
          "group": "deot_1"
        },
        {
          "submenu": "deot.lsp.restart",
          "when": "config.deot.showMenu",
          "group": "deot_1"
        },
        {
          "submenu": "deot.sm",
          "when": "config.deot.showMenu && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "deot_1"
        }
      ],
      "deot.lsp.fix": [
          {
            "command": "deot.lsp.fix.all",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.fix.js",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.fix.css",
            "when": "editorFocus"
          }
      ],
      "deot.lsp.restart": [
          {
            "command": "deot.lsp.restart.all",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.restart.js",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.restart.css",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.restart.vue",
            "when": "editorFocus"
          },
          {
            "command": "deot.lsp.restart.ts",
            "when": "editorFocus"
          }
      ],
      "deot.sm": [
        {
          "command": "deotsm.openInSublimeMerge",
          "when": "config.deotsm.showMenu.openInSublimeMerge && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@1"
        },
        {
          "command": "deotsm.fileHistoryInSublimeMerge",
          "when": "config.deotsm.showMenu.fileHistoryInSublimeMerge == 'always' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@2"
        },
        {
          "command": "deotsm.fileHistoryInSublimeMerge",
          "when": "!editorHasSelection && config.deotsm.showMenu.fileHistoryInSublimeMerge == 'withoutSelection' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@2"
        },
        {
          "command": "deotsm.lineHistoryInSublimeMerge",
          "when": "config.deotsm.showMenu.lineHistoryInSublimeMerge == 'always' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@3"
        },
        {
          "command": "deotsm.lineHistoryInSublimeMerge",
          "when": "editorHasSelection && config.deotsm.showMenu.lineHistoryInSublimeMerge == 'withSelection' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@3"
        },
        {
          "command": "deotsm.myCommitsInSublimeMerge",
          "when": "config.deotsm.showMenu.myCommitsInSublimeMerge == 'always' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@5"
        },
        {
          "command": "deotsm.myCommitsInSublimeMerge",
          "when": "!editorHasSelection && config.deotsm.showMenu.myCommitsInSublimeMerge == 'withoutSelection' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@5"
        },
        {
          "command": "deotsm.blameInSublimeMerge",
          "when": "config.deotsm.showMenu.blameInSublimeMerge == 'always' && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@4"
        },
        {
          "command": "deotsm.blameInSublimeMerge",
          "when": "editorHasSelection && config.deotsm.showMenu.blameInSublimeMerge == 'withSelection'  && config.git.enabled && gitOpenRepositoryCount != 0",
          "group": "vscode_sublmerge@4"
        }
      ],
      "explorer/context": [
        {
          "command": "deot.duplicateFile",
          "when": "config.deot.showMenu",
          "group": "5_cutcopypaste@99"
        },
        {
          "command": "explorer.newFile",
          "when": "config.deot.showMenu && !explorerResourceIsFolder && !inputFocus",
          "group": "1_deot"
        },
        {
          "command": "explorer.newFolder",
          "when": "config.deot.showMenu && !explorerResourceIsFolder && !inputFocus",
          "group": "1_deot"
        }
      ]
    },
    "submenus": [
      {
        "id": "deot.lsp.fix",
        "label": "LSP Fix"
      },
      {
        "id": "deot.lsp.restart",
        "label": "LSP Restart"
      },
      {
        "id": "deot.sm",
        "label": "Sublime Merge"
      }
    ],
    "configuration": {
      "title": "Deot Preferences",
      "properties": {
        "deot.showMenu": {
          "type": "boolean",
          "default": true
        },
        "deotsm.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Set to false to disable the Sublime Merge for VSCode status bar item"
        },
        "deotsm.showBranchName": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, it will also show the current branch name in the status bar"
        },
        "deotsm.statusBarItemPosition": {
          "type": "string",
          "default": "right",
          "enum": [
            "left",
            "right"
          ],
          "description": "Position of the status bar item (requires restart)"
        },
        "deotsm.showMenu.openInSublimeMerge": {
          "type": "boolean",
          "default": true,
          "description": "Show the \"Open repository in Sublime Merge\" command in the contextual menu"
        },
        "deotsm.showMenu.fileHistoryInSublimeMerge": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "withoutSelection",
            "never"
          ],
          "enumDescriptions": [
            "Always show",
            "Show only when no text is selected",
            "Don't show"
          ],
          "description": "Show the \"File history in Sublime Merge\" command in the contextual menu"
        },
        "deotsm.showMenu.myCommitsInSublimeMerge": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "withoutSelection",
            "never"
          ],
          "enumDescriptions": [
            "Always show",
            "Show only when no text is selected",
            "Don't show"
          ],
          "description": "Show the \"Show my commits in Sublime Merge\" command in the contextual menu"
        },
        "deotsm.showMenu.lineHistoryInSublimeMerge": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "withSelection",
            "never"
          ],
          "enumDescriptions": [
            "Always show",
            "Show only when some text is selected",
            "Don't show"
          ],
          "description": "Show the \"Line history in Sublime Merge\" command in the contextual menu"
        },
        "deotsm.showMenu.blameInSublimeMerge": {
          "type": "string",
          "default": "always",
          "enum": [
            "always",
            "withSelection",
            "never"
          ],
          "enumDescriptions": [
            "Always show",
            "Show only when some text is selected",
            "Don't show"
          ],
          "description": "Show the \"Blame in Sublime Merge\" command in the contextual menu"
        },
        "deotsm.smergeExecutablePath": {
          "type": [
            "string",
            "object"
          ],
          "description": "Allows to specify the full path to the \"smerge\" executable",
          "properties": {
            "linux": {
              "type": "string",
              "description": "Full path to the \"smerge\" executable on Linux"
            },
            "osx": {
              "type": "string",
              "description": "Full path to the \"smerge\" executable on macOS"
            },
            "windows": {
              "type": "string",
              "description": "Full path to the \"smerge\" executable on Windows"
            }
          }
        },
        "deotsm.debug": {
          "type": "boolean",
          "default": false,
          "description": "Set to true to enable debug mode (requires restart)"
        }
      }
    }
  },
  "scripts": {
    "publish": "npm run vscode:prepublish && vsce package && vsce publish",
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "1.x",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}