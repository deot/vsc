{
  "name": "vsc-preferences",
  "displayName": "Deot Preferences",
  "description": "Personal Theme & Commands",
  "version": "1.0.5",
  "publisher": "deot",
  "repository": "https://dev.azure.com/zrd0921/vsc/_git/vsc",
  "engines": {
    "vscode": "^1.0.0"
  },
  "categories": [
    "Themes",
    "Formatters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Deot Theme Darker",
        "uiTheme": "vs-dark",
        "path": "./themes/deot-theme-darker.json"
      }
    ],
    "commands": [
      {
        "command": "revealFileInOS",
        "title": "Reveal In Finder"
      },
      {
        "command": "copyFilePath",
        "title": "Copy File Path"
      },
      {
        "command": "explorer.newFile",
        "title": "New File"
      },
      {
        "command": "explorer.newFolder",
        "title": "New Folder"
      },
      {
        "command": "workbench.action.terminal.openNativeConsole",
        "title": "Open Terminal Here"
      },
      {
        "command": "deot.debug",
        "title": "dd/Debug"
      },
      {
        "command": "deot.setSyntax",
        "title": "ss/Set Syntax"
      },
      {
        "command": "deot.pasteAndIndent",
        "title": "pasteAndIndent"
      },
      {
        "command": "deot.2spaceToTab",
        "title": "2spaceToTab"
      },
      {
        "command": "deot.4spaceToTab",
        "title": "4spaceToTab"
      },
      {
        "command": "deot.duplicateFile",
        "title": "Duplicate"
      }
    ],
    "keybindings": [
      {
        "key": "cmd+2",
        "command": "deot.2spaceToTab",
        "when": "editorFocus"
      },
      {
        "key": "cmd+4",
        "command": "deot.4spaceToTab",
        "when": "editorFocus"
      },
      {
        "key": "cmd+shift+v",
        "command": "deot.pasteAndIndent",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "key": "cmd+alt+1",
        "command": "workbench.action.editorLayoutSingle"
      },
      {
        "key": "cmd+alt+2",
        "command": "workbench.action.editorLayoutTwoColumns"
      },
      {
        "key": "cmd+alt+3",
        "command": "workbench.action.editorLayoutThreeColumns"
      },
      {
        "key": "cmd+alt+4",
        "command": "workbench.action.editorLayoutFourColumns"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "revealFileInOS",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        },
        {
          "command": "workbench.action.terminal.openNativeConsole",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        },
        {
          "command": "copyFilePath",
          "when": "config.deot.showMenu && editorFocus",
          "group": "deot"
        }
      ],
      "explorer/context": [
        {
          "command": "deot.duplicateFile",
          "when": "config.deot.showMenu",
          "group": "5_cutcopypaste@99"
        },
        {
          "command": "explorer.newFile",
          "when": "config.deot.showMenu && !explorerResourceIsFolder && !inputFocus",
          "group": "1_deot"
        },
        {
          "command": "explorer.newFolder",
          "when": "config.deot.showMenu && !explorerResourceIsFolder && !inputFocus",
          "group": "1_deot"
        }
      ]
    },
    "configuration": {
      "title": "Deot Preferences",
      "properties": {
        "deot.showMenu": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "publish": "npm run vscode:prepublish && vsce package && vsce publish",
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "1.x",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}